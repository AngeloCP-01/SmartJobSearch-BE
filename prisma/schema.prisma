generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  Draft
  Applied
  HR_Screening
  Technical_Interview
  Final_Interview
  Offer
  Accepted
  Rejected
  Withdrawn
}

enum WorkMode {
  Remote
  Hybrid
  OnSite
}

enum InterviewType {
  HR
  Technical
  Managerial
  Final
}

enum InterviewResult {
  Pending
  Passed
  Failed
}

enum DocumentType {
  Resume
  CoverLetter
  Other
}

enum ActivityAction {
  ApplicationCreated
  ApplicationStatusChanged
  ApplicationDeleted
  InterviewScheduled
  InterviewResultRecorded
  DocumentLinked
  ContactLinked
}

enum AuthoredDocType {
  Resume
  CoverLetter
  Note
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String?
  createdAt     DateTime       @default(now())
  companies     Company[]
  applications  Application[]
  interviews    Interview[]
  contacts      Contact[]
  documents     Document[]
  activityLogs  ActivityLog[]
  resumeAnalyses ResumeAnalysis[]
  refreshTokens RefreshToken[]
  authoredDocuments AuthoredDocument[]
  images        Image[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model Company {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  industry     String?
  website      String?
  location     String?
  size         String?
  notes        String?
  createdAt    DateTime      @default(now())
  applications Application[]
  contacts     Contact[]

  @@index([userId])
}

model Application {
  id              String            @id @default(uuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId       String?
  company         Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  position        String
  status          ApplicationStatus @default(Draft)
  applicationDate DateTime?
  salaryMin       Int?
  salaryMax       Int?
  source          String?
  workMode        WorkMode?
  jobDescription  String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  interviews      Interview[]
  contactLinks    ApplicationContact[]
  documentLinks   ApplicationDocument[]
  authoredDocuments AuthoredDocument[]
  activityLogs    ActivityLog[]
  resumeAnalyses  ResumeAnalysis[]

  @@index([userId])
}

model Interview {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String
  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          InterviewType
  scheduledAt   DateTime?
  interviewer   String?
  notes         String?
  result        InterviewResult?
  createdAt     DateTime         @default(now())

  @@index([userId])
  @@index([applicationId])
}

model Contact {
  id               String               @id @default(uuid())
  userId           String
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId        String?
  company          Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name             String
  email            String?
  position         String?
  phone            String?
  linkedinUrl      String?
  notes            String?
  followUpDate     DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  applicationLinks ApplicationContact[]

  @@index([userId])
  @@index([companyId])
}

model ApplicationContact {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([applicationId, contactId])
  @@index([applicationId])
  @@index([contactId])
}

model Document {
  id               String                @id @default(uuid())
  userId           String
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  type             DocumentType          @default(Resume)
  notes            String?
  originalFilename String
  mimeType         String
  sizeBytes        Int
  storageKey       String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  applicationLinks ApplicationDocument[]
  resumeAnalyses   ResumeAnalysis[]
  chunks           DocumentChunk[]

  @@index([userId])
}

// RAG: one row per embedded chunk of a Document. The `embedding` column is
// pgvector's type, which Prisma can't represent, so it is Unsupported and all
// reads/writes go through raw SQL. The extension lives in `public` and the type
// is schema-qualified so it resolves under any connection search_path (the test
// harness runs each Jest worker in its own schema — see tests/helpers/globalSetup.js).
model DocumentChunk {
  id         String                          @id @default(uuid())
  documentId String
  document   Document                        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  chunkIndex Int
  content    String
  embedding  Unsupported("public.vector(1024)")
  createdAt  DateTime                        @default(now())

  @@index([userId])
  @@index([documentId])
}

model AuthoredDocument {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  type          AuthoredDocType @default(Note)
  content       Json
  applicationId String?
  application   Application?    @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([applicationId])
}

model ApplicationDocument {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  documentId    String
  document      Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([applicationId, documentId])
  @@index([applicationId])
  @@index([documentId])
}

model ActivityLog {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  action        ActivityAction
  applicationId String?
  application   Application?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  metadata      Json           @default("{}")
  createdAt     DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([applicationId])
}

model ResumeAnalysis {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  documentId    String?
  document      Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  atsScore      Int
  matchScore    Int?
  report        Json         @default("{}")
  createdAt     DateTime     @default(now())

  @@index([userId, createdAt])
}

model Image {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storageKey String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  @@index([userId])
}
