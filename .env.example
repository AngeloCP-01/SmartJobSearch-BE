DATABASE_URL="postgresql://crm:crm@localhost:5434/jobcrm?schema=public"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
# Exact frontend origin (no trailing slash). In production set this to the
# deployed frontend URL, e.g. https://smartjobsearch.vercel.app.
CORS_ORIGIN="http://localhost:5173"
PORT=4000

# NODE_ENV=production also flips the refresh cookie to SameSite=None; Secure
# (required for cross-site FE↔API) and trusts the host proxy. Leave unset locally.
# NODE_ENV=production

# Documents storage driver: "local" (default) writes to disk; "s3" uses an
# S3-compatible object store (recommended in production so uploads survive
# redeploys on ephemeral-disk hosts).
STORAGE_DRIVER="local"

# --- local driver ---
# Where uploaded résumé/cover-letter files are stored on disk (gitignored).
# Defaults to ./uploads if unset.
UPLOAD_DIR="./uploads"

# --- s3 driver (STORAGE_DRIVER=s3) ---
# Works with any S3-compatible API. Examples:
#   Supabase Storage: S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
#   Cloudflare R2:    S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ENDPOINT="https://<project-ref>.storage.supabase.co/storage/v1/s3"
# S3_REGION="us-east-1"          # Supabase: your project region; R2: "auto"
# S3_BUCKET="documents"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_FORCE_PATH_STYLE="true"     # default true; set "false" only for AWS S3 itself

# Public base URL of THIS API (used to build absolute <img> URLs for editor images).
# Include the /api path, e.g. https://smartjobsearch-api.onrender.com/api
# Falls back to the request host when unset.
# PUBLIC_API_URL="https://smartjobsearch-api.onrender.com/api"

# Résumé Analysis — optional AI layer (OpenRouter, OpenAI-compatible).
# Leave OPENROUTER_API_KEY unset to keep the analysis fully deterministic
# (the "Use AI" toggle stays disabled). Set it to enable AI matching.
# OPENROUTER_API_KEY="sk-or-..."
# Comma-separated fallback list, tried in order until one responds. Each entry
# may carry a "<provider>:" prefix to route it to that provider (default is
# OpenRouter). Known providers: `nvidia` (NVIDIA NIM) and `openrouter`. A ":free"
# suffix is an OpenRouter model, not a provider prefix.
# Stabilized 2026-07-13 (live-probed): an all-NVIDIA chain is reliable and fast
# (~3-6s). NVIDIA's `qwen/qwen3-next-80b-a3b-instruct` was DROPPED — it reliably
# timed out (>45s) both probe runs; the OpenRouter free tier is flaky (404/429/
# timeout). gpt-oss-120b leads (best quality), llama-3.1-70b/8b are the backups.
OPENROUTER_MODEL="nvidia:openai/gpt-oss-120b,nvidia:meta/llama-3.1-70b-instruct,nvidia:meta/llama-3.1-8b-instruct"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# NVIDIA NIM (build.nvidia.com) — required only if the chain uses an `nvidia:` model.
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
# NVIDIA_OPENAI_KEY="nvapi-..."
# Optional resilience tuning: attempts per model, backoff base (ms), and the max
# Retry-After (ms) we'll wait to re-sweep when ALL models are rate-limited at once
# (set to 0 to disable that final re-sweep).
# OPENROUTER_ATTEMPTS=3
# OPENROUTER_RETRY_BASE_MS=400
# OPENROUTER_RETRY_AFTER_MAX_MS=10000
# RAG embeddings (NVIDIA NIM). Uses the provider routing + NVIDIA_* creds above.
EMBEDDING_MODEL="nvidia:nvidia/nv-embedqa-e5-v5"

# Error tracking (Sentry). Leave unset locally — Sentry stays fully disabled.
# Get the DSN from your Sentry project: Settings → Client Keys (DSN).
SENTRY_DSN=
# Fraction of performance traces to sample. Leave 0 — we track errors only.
SENTRY_TRACES_SAMPLE_RATE=0
