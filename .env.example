DATABASE_URL="postgresql://crm:crm@localhost:5434/jobcrm?schema=public"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
CORS_ORIGIN="http://localhost:5173"
PORT=4000

# Documents — where uploaded résumé/cover-letter files are stored on disk
# (gitignored). Defaults to ./uploads if unset.
UPLOAD_DIR="./uploads"

# Résumé Analysis — optional AI layer (OpenRouter, OpenAI-compatible).
# Leave OPENROUTER_API_KEY unset to keep the analysis fully deterministic
# (the "Use AI" toggle stays disabled). Set it to enable AI matching.
# OPENROUTER_API_KEY="sk-or-..."
# A free model that supports structured outputs; override as you like.
# See openrouter.ai/models?supported_parameters=structured_outputs
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
