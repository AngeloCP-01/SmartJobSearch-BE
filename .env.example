DATABASE_URL="postgresql://crm:crm@localhost:5434/jobcrm?schema=public"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
CORS_ORIGIN="http://localhost:5173"
PORT=4000

# Documents — where uploaded résumé/cover-letter files are stored on disk
# (gitignored). Defaults to ./uploads if unset.
UPLOAD_DIR="./uploads"

# Résumé Analysis — optional AI layer (OpenRouter, OpenAI-compatible).
# Leave OPENROUTER_API_KEY unset to keep the analysis fully deterministic
# (the "Use AI" toggle stays disabled). Set it to enable AI matching.
# OPENROUTER_API_KEY="sk-or-..."
# Comma-separated fallback list, tried in order until one responds. Free models
# vary — some are rate-limited or ignore the schema — so list a few; pick from
# openrouter.ai/models?supported_parameters=structured_outputs
OPENROUTER_MODEL="openai/gpt-oss-20b:free,nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3-next-80b-a3b-instruct:free"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# Optional resilience tuning: attempts per model, backoff base (ms), and the max
# Retry-After (ms) we'll wait to re-sweep when ALL models are rate-limited at once
# (set to 0 to disable that final re-sweep).
# OPENROUTER_ATTEMPTS=3
# OPENROUTER_RETRY_BASE_MS=400
# OPENROUTER_RETRY_AFTER_MAX_MS=10000
